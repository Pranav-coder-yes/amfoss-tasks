def diamond(n):
    for i in range(n):
        for f in range(n-i-1):
            print(' ', end='')
        for f in range(2*i+1):
            print('*', end='')
        print()
    for i in range(n-2,-1,-1):
        for b in range(n-i-1):
            print(' ', end='')
        for b in range(2*i+1):
            print('*', end='')
        print()

def run():
    n = int(input("Enter a number to form a Diamond Pattern: "))
    diamond(n)
run()
